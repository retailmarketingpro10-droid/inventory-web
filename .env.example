# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# Restart the dev server after changes:
#   npm run dev

# -----------------------------------------------------------------------------
# PayU — web subscription checkout (Monthly ₹500 / Yearly ₹3000)
# Get test credentials from https://dashboard.payu.in/
# -----------------------------------------------------------------------------
VITE_PAYU_MERCHANT_KEY=
VITE_PAYU_MERCHANT_SALT=
VITE_PAYU_TEST_MODE=true

# Public site URL (used for PayU success/failure redirects)
# Local dev:
VITE_URL=http://localhost:8080
# Production example:
# VITE_URL=https://inventory.retailmarketingpro.in

# -----------------------------------------------------------------------------
# Contact form (Auth → Support) — https://web3forms.com
# -----------------------------------------------------------------------------
# VITE_WEB3FORMS_ACCESS_KEY=

# -----------------------------------------------------------------------------
# AI report chat (optional) — Reports → AI assistant
# -----------------------------------------------------------------------------
# VITE_GEN_AI_API_KEY=
# VITE_GEN_AI_MODEL_ID=
